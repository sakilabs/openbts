server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    ssl_certificate /etc/letsencrypt/live/{{ openbts_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ openbts_domain }}/privkey.pem;

    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate /etc/letsencrypt/live/{{ openbts_domain }}/chain.pem;

    server_name {{ openbts_domain }};

    include /etc/nginx/conf.d/allow-cloudflare.conf;

    location /uploads {
        proxy_pass http://localhost:3030/uploads;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_buffering off;
    }

    location /api {
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Server $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass http://localhost:3030/api;
        proxy_pass_request_headers on;
        proxy_buffering off;
        proxy_store off;
    }

    location / {
        proxy_pass http://localhost:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_http_version 1.1;
    }
}
