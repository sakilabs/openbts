{
  "name": "@openbts/drizzle",
  "version": "1.0.0",
  "private": true,
  "description": "Drizzle schemas",
  "type": "module",
  "exports": {
    ".": {
      "types": "./schemas/index.ts",
      "default": "./dist/schemas/index.js"
    },
    "./types": {
      "types": "./schemas/types.ts",
      "default": "./dist/schemas/types.js"
    },
    "./db": {
      "types": "./db.ts",
      "default": "./dist/db.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx migrate.ts",
    "db:migrate:kit": "drizzle-kit migrate",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-rc.3",
    "nanoid": "5.1.11",
    "postgres": "3.4.9",
    "redis": "6.0.0",
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@openbts/typescript-configs": "workspace:*",
    "@types/node": "25.9.3",
    "drizzle-kit": "1.0.0-rc.3"
  }
}
