{
  "name": "@openbts/uke-importer",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./stations": {
      "types": "./src/stations.ts",
      "default": "./dist/stations.js"
    },
    "./radiolines": {
      "types": "./src/radiolines.ts",
      "default": "./dist/radiolines.js"
    },
    "./device-registry": {
      "types": "./src/device-registry.ts",
      "default": "./dist/device-registry.js"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./dist/utils.js"
    },
    "./kmz/stations": {
      "types": "./src/kmz/stations.ts",
      "default": "./dist/kmz/stations.js"
    },
    "./kmz/radiolines": {
      "types": "./src/kmz/radiolines.ts",
      "default": "./dist/kmz/radiolines.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "start": "tsx src/index.ts",
    "kmz": "tsx src/kmz/index.ts"
  },
  "dependencies": {
    "@openbts/drizzle": "workspace:*",
    "@openbts/shared": "workspace:*",
    "@turf/boolean-point-in-polygon": "7.3.5",
    "@turf/helpers": "7.3.5",
    "cheerio": "1.2.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-beta.22",
    "fflate": "^0.8.2",
    "geojson-rbush": "~3.2.0",
    "postgres": "3.4.9",
    "tsx": "4.21.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@openbts/typescript-configs": "workspace:*",
    "@types/geojson": "^7946.0.16",
    "@types/node": "20"
  }
}
