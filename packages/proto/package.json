  },
  "devDependencies": {
    "@bufbuild/buf": "1.69.0",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@openbts/typescript-configs": "workspace:*",
    "@types/node": "22.19.17"
  },
  "packageManager": "pnpm@11.0.3"
}
