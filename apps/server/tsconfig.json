{
  "extends": "@openbts/typescript-configs/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "dist", "src/v1/old/**/*"]
}
